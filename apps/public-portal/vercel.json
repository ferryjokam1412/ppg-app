{
  "rewrites": [
    { 
      "source": "/admin-assets/:path*", 
      "destination": "https://ppg-app-admin-portal.vercel.app/admin-assets/:path*" 
    },
    { 
      "source": "/admin/:path*", 
      "destination": "https://ppg-app-admin-portal.vercel.app/:path*" 
    },
    { 
      "source": "/((?!admin|admin-assets).*)", 
      "destination": "/index.html" 
    }
  ]
}